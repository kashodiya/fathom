# LLM Configuration
# Copy this file to .env and configure your settings

# ============================================================================
# LLM Provider: "bedrock" or "openai"
# ============================================================================
LLM_PROVIDER=bedrock

# ============================================================================
# AWS Bedrock Configuration (when LLM_PROVIDER=bedrock)
# ============================================================================
# AWS region where Bedrock is available
AWS_REGION=us-east-1

# Model ID for Bedrock
# Options:
# - us.anthropic.claude-haiku-4-5-20251001-v1:0 (fast, cheap)
# - us.anthropic.claude-sonnet-4-6-20250929-v1:0 (balanced)
# - us.anthropic.claude-opus-4-6-20250929-v1:0 (most capable)
LLM_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# AWS credentials (optional - can use AWS CLI or IAM roles instead)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# ============================================================================
# OpenAI-Compatible API Configuration (when LLM_PROVIDER=openai)
# ============================================================================
# Base URL for the API endpoint
# Examples:
# - Anthropic API: https://api.anthropic.com/v1
# - OpenAI API: https://api.openai.com/v1
# - Local LLM: http://localhost:11434/v1
# LLM_BASE_URL=https://api.anthropic.com/v1

# API Key (REQUIRED when using openai provider)
# LLM_API_KEY=your_api_key_here

# Model ID for OpenAI-compatible API
# Examples:
# - Anthropic: claude-sonnet-4-20250514, claude-opus-4-20250514
# - OpenAI: gpt-4o, gpt-4-turbo
# - Ollama: llama3.2, mistral
# LLM_MODEL_ID=claude-sonnet-4-20250514
